# ============================================================
# pSEO Automation System - Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Database ---
DATABASE_URL=sqlite:///./pseo.db
# For production: postgresql://user:password@localhost:5432/pseo

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-dHZq6BmbHYziuhKDxaDBGDyour_openai_api_key_here
LLM_MODEL=gpt-4.1-mini
# Alternatively use: gemini-2.5-flash

# --- Google Search Console / Indexing API ---
# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=config/google_service_account.json

# --- Ahrefs API (for competitor monitoring) ---
AHREFS_API_KEY=your_ahrefs_api_key_here

# --- Notification (Feishu/Lark Webhook) ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# --- Target Website ---
SITE_URL=https://your-ai-tool-site.com

# --- pSEO Engine Settings ---
PSEO_BATCH_SIZE=10
PSEO_MIN_WORD_COUNT=800
