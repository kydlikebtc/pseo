# =============================================================================
# pSEO Automation System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values marked as [REQUIRED].
# Keys marked [AUTO] are injected automatically when running inside Manus.
# Keys marked [FREE] require no payment — free tier is sufficient.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Configuration  [AUTO — no action needed when running inside Manus]
# -----------------------------------------------------------------------------
# When running inside Manus, OPENAI_API_KEY and OPENAI_BASE_URL are
# pre-injected by the runtime. You do NOT need to set these manually.
#
# When running locally (outside Manus), set OPENAI_API_KEY to your own key.
# Supported models: any model name is accepted. Current Manus-supported models:
#   gpt-4.1-mini (default) | gpt-4.1-nano | gemini-2.5-flash
# When running locally with your own key, any model is supported:
#   OpenAI   : gpt-4o | gpt-4o-mini | o3 | o4-mini
#   Anthropic: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
#   Google   : gemini-2.5-pro | gemini-2.5-flash
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4.1-mini        # Default. Any model name accepted — see examples above.


# -----------------------------------------------------------------------------
# Database  [OPTIONAL — defaults to local SQLite, no setup needed]
# -----------------------------------------------------------------------------
# For production use PostgreSQL: postgresql://user:pass@host:5432/pseo
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./pseo.db


# -----------------------------------------------------------------------------
# Your Website  [REQUIRED]
# -----------------------------------------------------------------------------
SITE_URL=https://your-ai-tool-site.com


# -----------------------------------------------------------------------------
# SimilarWeb — Competitor Traffic Monitoring  [AUTO inside Manus / FREE]
# -----------------------------------------------------------------------------
# When running inside Manus: SimilarWeb data is available via built-in ApiClient.
# NO API KEY REQUIRED. Real monthly traffic, organic ratio, global rank are
# fetched automatically for any competitor domain.
#
# When running locally (outside Manus): the system falls back to mock data.
# To use real data locally, sign up at https://www.similarweb.com/corp/developer/
# and set your API key below (free tier: 1,000 requests/month).
# -----------------------------------------------------------------------------
SIMILARWEB_API_KEY=          # Optional — only needed when running outside Manus


# -----------------------------------------------------------------------------
# Semrush — Backlink Opportunity Discovery  [FREE tier available]
# -----------------------------------------------------------------------------
# Semrush free tier: 10 API requests/day, sufficient for weekly backlink scans.
# Steps to obtain:
#   1. Sign up at https://www.semrush.com (free account)
#   2. Go to https://www.semrush.com/api-documentation/
#   3. Copy your API key from the dashboard
#
# Without this key, the system uses mock backlink data for demonstration.
# -----------------------------------------------------------------------------
SEMRUSH_API_KEY=


# -----------------------------------------------------------------------------
# Google Search Console — Indexing API  [REQUIRED for auto-indexing]
# -----------------------------------------------------------------------------
# Steps to obtain:
#   1. Go to https://console.cloud.google.com
#   2. Create a service account with "Owner" role in Search Console
#   3. Download the JSON key file → place at config/google_service_account.json
#   4. In Search Console, add the service account email as an owner
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_FILE=config/google_service_account.json


# -----------------------------------------------------------------------------
# Feishu (Lark) Webhook  [OPTIONAL — for team alert notifications]
# -----------------------------------------------------------------------------
# Create a custom bot in your Feishu group and paste the webhook URL here.
# Alerts fire on: competitor traffic surges, new DR 30-60 backlink opportunities,
# and critical SEO audit failures.
# -----------------------------------------------------------------------------
FEISHU_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# pSEO Engine Settings  [OPTIONAL]
# -----------------------------------------------------------------------------
PSEO_BATCH_SIZE=10
PSEO_MIN_WORD_COUNT=800
